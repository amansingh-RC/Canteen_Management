# Copy to `.env` and adjust when wiring the real backend.

# Base URL the HTTP client prepends to every request path.
VITE_API_BASE_URL=/api

# Keep "true" to serve local mock data (src/data). Set "false" to hit the API.
VITE_USE_MOCK=true

# Socket.IO server URL for real-time screens (e.g. Live Monitoring).
# Use the backend origin; "/" works for same-origin / Vite-proxied setups.
VITE_SOCKET_URL=http://localhost:5000
